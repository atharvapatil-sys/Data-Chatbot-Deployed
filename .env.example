# ============================================================
# InsightStream — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# Deployment checklist:
#   Vercel   → add all variables under Project → Settings → Environment Variables
#   Docker   → pass via --env-file .env or Cloud Run secret manager
#   Local    → copy to .env (already in .gitignore)
# ============================================================

# ── Google OAuth 2.0 ─────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
#
# Add ALL of the following as Authorized Redirect URIs:
#   Local dev : http://localhost:3000/auth/callback
#   Vercel    : https://<your-project>.vercel.app/auth/callback
#   Docker    : https://<your-domain>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Cloud — BigQuery ───────────────────────────────────
# GCP Project ID where your BigQuery datasets live.
# The app requests the bigquery.readonly scope — no write access is granted.
BIGQUERY_PROJECT_ID=
# Default query location (US or EU). Defaults to US if not set.
BIGQUERY_LOCATION=US

# ── Google Gemini API Key ─────────────────────────────────────
# Obtain at: https://aistudio.google.com/app/apikey
# IMPORTANT: SERVER-SIDE ONLY — this value is never sent to the browser.
GEMINI_API_KEY=

# Optional model overrides (defaults shown below)
# GEMINI_MODEL_PRO=gemini-2.5-pro
# GEMINI_MODEL_FLASH=gemini-2.5-flash

# ── Session Security ──────────────────────────────────────────
# Generate a strong random string:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED in production. The server will refuse to start without it.
SESSION_SECRET=

# ── Application URL ───────────────────────────────────────────
# Used to build OAuth redirect URIs and postMessage targets.
# Set this to your deployed URL — no trailing slash.
#   Vercel : https://<your-project>.vercel.app
#   Docker : https://your-custom-domain.com
# Defaults to the Cloud Run dev URL when not set.
# APP_URL=https://your-app.vercel.app

# ── Server Port ───────────────────────────────────────────────
# Vercel ignores this (it manages the port). Useful for Docker / local.
# PORT=3000
